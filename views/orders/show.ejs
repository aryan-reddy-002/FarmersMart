<% layout('layouts/boilerplate') %>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">Order Confirmation</h3>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <h6 class="text-muted">Order ID:</h6>
                            <p class="fw-bold text-uppercase"><%= order._id %></p>
                        </div>
                        <div class="col-sm-6 text-sm-end">
                            <h6 class="text-muted">Order Date:</h6>
                            <p><%= order.createdAt.toDateString() %></p>
                        </div>
                    </div>

                    <h5>Shipping Details</h5>
                    <p class="mb-0"><strong>Name:</strong> <%= order.buyer.username %></p>
                    <p><strong>Address:</strong> <%= order.shippingAddress %></p>
                    <hr>

                    <h5>Items Purchased</h5>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% order.items.forEach(item => { %>
                                    <tr>
                                        <td><%= item.name %></td>
                                        <td class="text-center"><%= item.quantity %></td>
                                        <td class="text-end">₹<%= item.price %></td>
                                        <td class="text-end">₹<%= (item.price * item.quantity).toFixed(2) %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="3" class="text-end">Grand Total</th>
                                    <th class="text-end text-success">₹<%= order.totalAmount.toFixed(2) %></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <div class="mt-4">
                        <span class="badge bg-info p-2">Status: <%= order.orderStatus %></span>
                        <span class="badge bg-secondary p-2">Payment: <%= order.paymentMethod %></span>
                    </div>
                </div>
                
            </div>
        </div>
    </div>
</div>