<% layout('/layouts/boilerplate') %>
<body>
    

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-4">
<% for (let p of catProducts) { %>
    <div class="col">
        <div class="card h-100 shadow-sm border-0"> <img src="<%= p.image.url %>" class="card-img-top product-thumb">
            <div class="card-body d-flex flex-column">
                <h6 class="card-title"><%= p.name %></h6>

                <div class="mt-auto"> <% if(p.discount > 0){ %>
                        <p class="price-old mb-0">₹<%= p.price %></p>
                        <p class="price-new">₹ <%=p.price - (p.price * p.discount / 100) %></p> 
                    <% } else { %>
                        <p class="price-new">₹ <%= p.price %></p>
                    <% } %>
                    
                    <div class="d-grid gap-2">
                        <% 
                        let cartItem = null;
                        if(currUser) { 

                            cartItem = currUser.cart.find(item => item.product.equals(p._id));
                        } else if(typeof cartItems !== 'undefined') {
                            cartItem = cartItems.find(item => item.product == p._id);
                        }
                        %>

                        <% if (cartItem) { %>
                            <div class="btn-group border border-success rounded" role="group">
                                <button type="button" onclick="changeQty('<%= p._id %>', 'decreasing')" class="btn btn-sm btn-white text-success fw-bold">-</button>
                                <span id="qty-<%= p._id %>" class="btn btn-sm btn-white disabled text-dark px-3">
                                    <%= cartItem.quantity %>
                                </span>
                                <button type="button" onclick="changeQty('<%= p._id %>', 'increasing')" class="btn btn-sm btn-white text-success fw-bold">+</button>
                            </div>
                        <% } else { %>
                           <button onclick="addToCart('<%= p._id %>')" 
        class="btn btn-sm btn-outline-success"
        id="cart-btn-<%= p._id %>">
  Add to Cart
</button>
                        <% } %>
                        <a href="/products/<%= p._id %>" class="btn btn-sm btn-success">View Details</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
<% } %>

</div> 
<a href="/products" style="margin-top: 40px;"  class="btn btn-secondary">← Continue Shopping</a>




</body>