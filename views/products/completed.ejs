<% layout('layouts/boilerplate') %>

<div class="container text-center mt-5">

    <h2 class="text-warning">⚠️ Order Already Delivered</h2>

    <p class="mt-3">
        This order was already delivered earlier.
    </p>

    <p><strong>Order ID:</strong> <%= order._id %></p>

    <% if (order.deliveredAt) { %>
        <p><strong>Delivered At:</strong> <%= order.deliveredAt.toLocaleString() %></p>
    <% } %>

    <a href="/products" class="btn btn-primary mt-3">Go Home</a>

</div>