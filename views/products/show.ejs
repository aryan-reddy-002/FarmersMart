
<% layout('/layouts/boilerplate') %>

<div class="container mt-5 pt-4"> <div class="product-card p-3 p-md-4 shadow-sm">
        <div class="row g-4">
            <div class="col-md-6 text-center">
                <img src="<%= item.image.url %>" class="img-fluid rounded shadow-sm main-product-img" style="max-height: 400px; object-fit: contain;">
            </div>

            <div class="col-md-6">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2">
                        <li class="breadcrumb-item"><a href="/products" class="text-success">Shop</a></li>
                        <li class="breadcrumb-item active text-capitalize"><%= item.category %></li>
                    </ol>
                </nav>

                <h2 class="fw-bold mb-1"><%= item.name %></h2>
                
                <div class="d-flex align-items-center gap-2 mb-3">
                    <% if(item.discount > 0){ %>
                        <h3 class="text-success fw-bold mb-0">₹<%= item.price - (item.price * item.discount / 100) %></h3>
                        <span class="text-muted text-decoration-line-through">₹<%= item.price %></span>
                        <span class="badge bg-danger">SAVE <%= item.discount %>%</span>
                    <% } else { %>
                        <h3 class="text-success fw-bold mb-0">₹<%= item.price %></h3>
                    <% } %>
                </div>

                <p class="text-secondary"><%= item.description %></p>

                <div class="mb-4">
                    <span class="<%= item.quantity > 0 ? 'badge bg-success-subtle text-success border border-success' : 'badge bg-danger-subtle text-danger border border-danger' %> p-2 px-3">
                        <%= item.quantity > 0 ? '✔ In Stock' : '✖ Out of Stock' %>
                    </span>
                </div>

                <% if(role=="owner" && username=="farmersmart") {%>
                    <div class="mb-3 d-flex gap-2">
                        <a href="/products/<%= item._id %>/edit" class="btn btn-warning btn-sm px-4">Edit</a>
                        <form method="POST" action="/products/<%= item._id %>?_method=DELETE">
                            <button class="btn btn-outline-danger btn-sm px-4">Delete</button>
                        </form>
                    </div>
                <% } %>

                <hr>

                <div class="d-grid gap-2">
                     <button onclick="addToCart('<%= item._id %>')" class="btn btn-success btn-lg shadow-sm py-2">
                        <i class="fa-solid fa-cart-plus me-2"></i> Add to Cart
                     </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-8 mx-auto">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-pen-to-square me-2 text-success"></i>Drop a Review</h5>
                
                <form method="POST" action="/products/<%= item._id %>/review">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Rating</label>
                        <fieldset class="starability-slot">
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked />
                            <input type="radio" id="rate1" name="review[rating]" value="1" />
                            <label for="rate1">1</label>
                            <input type="radio" id="rate2" name="review[rating]" value="2" />
                            <label for="rate2">2</label>
                            <input type="radio" id="rate3" name="review[rating]" value="3" />
                            <label for="rate3">3</label>
                            <input type="radio" id="rate4" name="review[rating]" value="4" />
                            <label for="rate4">4</label>
                            <input type="radio" id="rate5" name="review[rating]" value="5" />
                            <label for="rate5">5</label>
                        </fieldset>
                    </div>

                    <div class="mb-3">
                        <textarea name="review[comment]" class="form-control" rows="3" placeholder="How was the product? Tell us about the quality..." required></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-success px-4 shadow-sm">Submit Review</button>
                        <a href="/products/<%= item._id %>/review/show" class="btn btn-outline-dark">View All Comments</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5 pb-5">
    <h4 class="fw-bold mb-4">You might also like</h4>
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
        <% for (let p of catProducts) { %>
            <div class="col">
                <div class="card h-100 shadow-sm border-0 product-card">
                    <img src="<%= p.image.url %>" class="card-img-top p-2" style="height: 150px; object-fit: contain;">
                    <div class="card-body p-2 d-flex flex-column text-center">
                        <h6 class="card-title text-truncate small mb-1"><%= p.name %></h6>
                        <p class="text-success fw-bold mb-2 mt-auto">₹<%= p.price %></p>
                        <a href="/products/<%= p._id %>" class="btn btn-outline-success btn-sm rounded-pill">View</a>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
    <div class="text-center mt-5">
        <a href="/products" class="btn btn-light border px-4 rounded-pill">← Back to All Products</a>
    </div>
</div>