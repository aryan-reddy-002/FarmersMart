

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>FarmersMart</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/rating.css">


</head>

<body>

<body class="app-body">

<%- include("../includes/navbar.ejs") %>
<!-- <div class="offcanvas offcanvas-end" id="userProfilePanel" data-bs-scroll="true"></div> -->

<main class="app-main">
  <div class="container">
    <%- body %>
  </div>
</main>

<%- include("../includes/footer.ejs") %>

</body>

<div class="offcanvas offcanvas-end" tabindex="-1" id="userProfilePanel" aria-labelledby="profileLabel">
    <div class="offcanvas-header bg-success text-white">
        <h5 class="offcanvas-title" id="profileLabel">User Account</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <% if (currUser) { %>
            <div class="text-center mb-4">
                <div class="bg-light rounded-circle d-inline-block p-3 mb-2 shadow-sm">
                    <i class="fa-solid fa-user-gear fa-3x text-success"></i>
                </div>
                <h4><%= currUser.username %></h4>
                <p class="text-muted small"><%= currUser.email %></p>
            </div>

            <hr>

            <ul class="list-group list-group-flush mb-4">
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <a href="/products/cart" class="text-decoration-none text-dark">
                        <i class="fa-solid fa-box-open me-2"></i> My Orders
                    </a>
                
            </ul>

            <div class="d-grid">
                <form action="/logout" method="get">
                    <button class="btn btn-danger w-100 shadow-sm" type="submit">Logout</button>
                </form>
            </div>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>
<script src="/js/cart.js"></script>
</body>
</html>


 
